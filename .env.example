# Public Frontend Environment Variables
# NEVER put real API keys, Secret Keys, or Service Role keys in this file.

# LARI Launch Mode Configuration
# Available launch modes:
# - local_pre_live (Yerel Hazırlık Sürümü)
# - internal_demo (Dahili Kurucu Demosu)
# - unpaid_manual_pilot (Ücretsiz Manuel Pilot)
# - limited_live_manual_billing (Kısıtlı Çevrimdışı Ödemeli Sürüm)
# - paymentless_limited_production (Ödemesiz Kısıtlı Canlı Üretim Sürümü)
# - full_live_online_payment (Tam Kredi Kartı Entegrasyonlu Canlı SaaS)
VITE_LAUNCH_MODE=local_pre_live

# Data Mode Configuration ('local' | 'supabase_staging' | 'supabase_production')
# NOTE: 'paymentless_limited_production' and 'full_live_online_payment' require a persistent ('supabase_*') database mode.
VITE_DATA_MODE=local

# Payment Mode Configuration ('disabled' | 'iyzico_sandbox' | 'iyzico_live')
# NOTE: For 'paymentless_limited_production', this MUST be set to 'disabled'.
VITE_PAYMENT_MODE=disabled

# Frontend Run Mode ('local_dry_run' | 'sandbox_live' | 'production_live')
VITE_PAYMENT_RUN_MODE=local_dry_run

# Mock / Sandbox / Production Provider
VITE_PAYMENT_PROVIDER=sandbox

# App URLs and Domains
VITE_APP_BASE_URL=http://localhost:3000
VITE_PUBLIC_SITE_BASE_URL=http://localhost:3000
VITE_PUBLIC_BASE_DOMAIN=randevulari.com

# Supabase (Public / Anon keys only)
# Required for persistent database modes (e.g. staging or production live)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Media Storage Mode ('local_preview' | 'supabase_storage' | 'external_provider')
VITE_MEDIA_STORAGE_MODE=local_preview

# Observability and Monitoring Configuration ('local_only' | 'sentry' | 'datadog' | 'opentelemetry')
VITE_OBSERVABILITY_MODE=local_only
OBSERVABILITY_PROVIDER=disabled
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
SUPPORT_ALERT_WEBHOOK_URL=

# Communication Run Mode (local_outbox_only | email_provider_ready | sms_provider_ready | whatsapp_provider_ready)
VITE_COMMUNICATION_MODE=local_outbox_only

# Scheduler / Background Cron Configuration
VITE_SCHEDULER_MODE=local_simulation
SCHEDULER_ENABLED=false

# ==========================================
# Backend / Edge Function Secret Variables
# (Used strictly in server/Supabase environment, NEVER prefix with VITE_)
# ==========================================

# Supabase Credentials (Never expose to browser)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Iyzico Credentials (Sandbox/Production)
# (Only required if VITE_LAUNCH_MODE is 'full_live_online_payment')
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# IYZICO_CALLBACK_URL=http://localhost:3000/booking/callback
# IYZICO_WEBHOOK_SECRET=

# Provider Delivery Modes (active | disabled)
# EMAIL_PROVIDER_MODE=disabled
# SMS_PROVIDER_MODE=disabled
# WHATSAPP_PROVIDER_MODE=disabled

# Communication Secrets
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
# SMS_PROVIDER_API_KEY=
# SMS_PROVIDER_USERNAME=
# SMS_PROVIDER_PASSWORD=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Scheduler / Background Secrets
# SCHEDULER_SECRET=
# DAILY_MAINTENANCE_CRON=0 2 * * *
# OUTBOX_RETRY_CRON=*/15 * * * *
# SUBSCRIPTION_SWEEP_CRON=0 1 * * *
