# Public Frontend Environment Variables
# NEVER put real API keys, Secret Keys, or Service Role keys in this file.

# Frontend Run Mode ('local_dry_run' | 'sandbox_live' | 'production_live')
VITE_PAYMENT_RUN_MODE=local_dry_run

# Mock / Sandbox / Production
VITE_PAYMENT_PROVIDER=sandbox
VITE_DATA_MODE=mock

# App URLs
VITE_APP_BASE_URL=http://localhost:3000
VITE_PUBLIC_SITE_BASE_URL=http://localhost:3000

# Supabase (Public / Anon keys only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend / Edge Function Secret Variables
# (Used in Supabase environment, never prefixed with VITE_)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# PUBLIC_APP_URL=

# Iyzico Credentials (Sandbox/Production)
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# IYZICO_CALLBACK_URL=http://localhost:3000/booking/callback (or edge function callback)
# IYZICO_WEBHOOK_SECRET=

# Communication Run Mode (local_outbox_only | email_provider_ready | sms_provider_ready | whatsapp_provider_ready)
VITE_COMMUNICATION_MODE=local_outbox_only

# Provider Delivery Modes (active | disabled)
EMAIL_PROVIDER_MODE=disabled
SMS_PROVIDER_MODE=disabled
WHATSAPP_PROVIDER_MODE=disabled

# Server/Edge-only Secret Keys (never use in frontend or prefix with VITE_)
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
# SMS_PROVIDER_API_KEY=
# SMS_PROVIDER_USERNAME=
# SMS_PROVIDER_PASSWORD=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Scheduler / Background Cron Configuration
VITE_SCHEDULER_MODE=local_simulation
SCHEDULER_ENABLED=false
# SCHEDULER_SECRET=
# DAILY_MAINTENANCE_CRON=0 2 * * *
# OUTBOX_RETRY_CRON=*/15 * * * *
# SUBSCRIPTION_SWEEP_CRON=0 1 * * *

# Observability and Monitoring Configuration
VITE_OBSERVABILITY_MODE=local_only
OBSERVABILITY_PROVIDER=disabled
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
SUPPORT_ALERT_WEBHOOK_URL=

