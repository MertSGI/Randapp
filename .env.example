# Database & Authentication Mode (mock or supabase)
# mock: Recommended for preview/local development
# supabase: Recommended for production deployment
VITE_DATA_MODE=mock
VITE_APP_BASE_DOMAIN=randapp.com

# Router Mode (hash or browser)
# hash: Use hash mode for embedded previews
# browser: Use browser mode for production deployments. BrowserRouter requires rewrite rules in production.
VITE_ROUTER_MODE=hash

# Satış ve Demo Yönlendirmeleri İçin WhatsApp Numarası (Uluslararası formatta, + olmadan ve boşluksuz. Örn: 905xxxxxxxxx)
VITE_SALES_WHATSAPP_NUMBER=905000000000

# Note: Service Worker is intentionally disabled until production caching strategy is finalized.

# Supabase Configuration
VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY is safe to expose in the frontend
VITE_SUPABASE_ANON_KEY=

# SECURITY WARNINGS FOR PRODUCTION:
# - SERVICE ROLE KEY: Never expose or use the Supabase Service Role Key in the frontend. 
# - GEMINI API KEY: Do not use VITE_GEMINI_API_KEY directly in the frontend for production. Create a backend proxy.
# - STRIPE/WHATSAPP: Never put secret tokens for third party services in the frontend.
