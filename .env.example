# Database & Authentication Mode (mock or supabase)
VITE_DATA_MODE=mock
VITE_APP_BASE_DOMAIN=randapp.com

# Supabase Configuration
VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY is safe to expose in the frontend
VITE_SUPABASE_ANON_KEY=

# SECURITY WARNINGS FOR PRODUCTION:
# - SERVICE ROLE KEY: Never expose or use the Supabase Service Role Key in the frontend. 
# - GEMINI API KEY: Do not use VITE_GEMINI_API_KEY directly in the frontend for production. Create a backend proxy.
# - STRIPE/WHATSAPP: Never put secret tokens for third party services in the frontend.
