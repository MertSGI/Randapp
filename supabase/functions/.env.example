# Supabase Edge Functions Environment Variables
# These secrets MUST NEVER be exposed to the frontend or committed to source control.
# Set them using: supabase secrets set --env-file supabase/functions/.env.production

# Iyzico Sandbox/Production Keys
IYZICO_API_KEY=replace_with_iyzico_api_key
IYZICO_SECRET_KEY=replace_with_iyzico_secret_key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Supabase Service Keys (Required for Admin actions like updating subscriptions)
SUPABASE_URL=replace_with_project_url
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Optional external integrations
GEMINI_API_KEY=replace_with_server_side_key_if_testing_ai
AI_PROVIDER=gemini
